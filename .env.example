# ============================================================
# .env.example — Copy this file to .env and fill in your values
# DO NOT commit your actual .env file to version control!
# ============================================================

# --- Database (PostgreSQL) ---
# When running with Docker Compose, use: postgresql+asyncpg://<user>:<pass>@db:5432/<dbname>
DATABASE_URL=postgresql+asyncpg://postgres:your_db_password@db:5432/operations_hub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=operations_hub

# --- JWT Authentication ---
SECRET_KEY=generate_a_strong_random_key_here
ALGORITHM=HS256

# --- Redis & Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- AWS (Leave blank on EC2 if using an IAM Instance Role — recommended) ---
# Only set these for local development. On EC2, assign an IAM Role instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-s3-bucket-name
DYNAMODB_TABLE_NAME=AuditLogs

# --- SMTP / Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# --- App Config ---
APP_BASE_URL=http://your-ec2-ip-or-domain:8000
INTERNAL_SERVICE_TOKEN=generate_a_strong_random_token_here
SQL_ECHO=false
